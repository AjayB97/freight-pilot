# Copy to .env for local dev. In production these are set via `fly secrets set`.

# Comma-separated list of API keys that can call the API.
API_KEYS=dev-local-key

# Pick any sqlite path you like. The Docker image uses /app/data/freight_pilot.db
DATABASE_URL=sqlite:///./data/freight_pilot.db

# Get one at https://mobile.fmcsa.dot.gov/QCDevsite/home
FMCSA_API_KEY=

# Dashboard origins allowed to call the API from a browser.
CORS_ORIGINS=http://localhost:3000

# Negotiation policy knobs (optional overrides)
NEGOTIATION_MAX_ROUNDS=3
NEGOTIATION_MAX_MARKUP_PCT=0.15
NEGOTIATION_MIN_FLOOR_PCT=0.92
